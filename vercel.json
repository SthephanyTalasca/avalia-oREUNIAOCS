{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ingest.js":  { "maxDuration": 30 },
    "api/analyze.js": { "maxDuration": 300 },
    "api/*.js":       { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/api/me",       "destination": "/api/auth?_route=me" },
    { "source": "/api/feedback", "destination": "/api/save?_route=feedback" },
    { "source": "/api/reassign", "destination": "/api/records?_route=reassign" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
