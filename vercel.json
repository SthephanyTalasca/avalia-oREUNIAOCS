{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/ingest.js":  { "maxDuration": 30 },
    "api/analyze.js": { "maxDuration": 300 },
    "api/*.js":       { "maxDuration": 30 }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
